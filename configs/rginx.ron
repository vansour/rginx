Config(
    runtime: RuntimeConfig(
        shutdown_timeout_secs: 10,
    ),
    server: ServerConfig(
        listen: "0.0.0.0:80",
        // TLS examples live in `example/rginx.ron`.
        // If you enable HTTPS here, run `rginx check` and the TLS release gate from README before deploying.
        // Example:
        // tls: Some(ServerTlsConfig(
        //     cert_path: "/etc/rginx/certs/default.crt",
        //     key_path: "/etc/rginx/certs/default.key",
        //     versions: Some([Tls12, Tls13]),
        //     ocsp_staple_path: Some("/var/cache/rginx/default.ocsp"),
        //     session_tickets: Some(false),
        // )),
        // Fresh installs should work without any upstream dependencies.
        // Reverse-proxy examples live in `example/rginx.ron`.
        // For per-vhost certificate overrides, see `configs/conf.d/default.ron`.
    ),
    upstreams: [],
    locations: [
        LocationConfig(
            matcher: Exact("/"),
            handler: Return(
                status: 200,
                location: "",
                body: Some("Welcome to rginx!\nIf you see this page, the rginx web server is successfully installed and working.\n"),
            ),
        ),
        LocationConfig(
            matcher: Exact("/healthz"),
            handler: Return(
                status: 200,
                location: "",
                body: Some("ok\n"),
            ),
        ),
    ],
    servers: [
        // @include "conf.d/*.ron"
    ],
)
