VirtualHostConfig(
    server_names: ["app.example.com"],
    // For per-vhost certificate overrides, see the commented TLS examples in `example/conf.d/default.ron`.
    locations: [
        LocationConfig(
            matcher: Exact("/"),
            handler: Return(
                status: 200,
                location: "",
                body: Some("app.example.com root\n"),
            ),
        ),
        LocationConfig(
            matcher: Prefix("/v1"),
            handler: Proxy(
                upstream: "backend",
            ),
        ),
    ],
),
