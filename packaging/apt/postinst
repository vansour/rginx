#!/bin/sh
set -e

create_rginx_user() {
    if getent passwd rginx >/dev/null 2>&1; then
        return 0
    fi

    shell=/usr/sbin/nologin
    if [ ! -x "$shell" ]; then
        shell=/usr/bin/false
    fi

    adduser \
        --system \
        --group \
        --home /var/lib/rginx \
        --no-create-home \
        --shell "$shell" \
        rginx >/dev/null 2>&1
}

case "$1" in
    configure)
        create_rginx_user
        mkdir -p /var/lib/rginx
        if getent passwd rginx >/dev/null 2>&1; then
            chown rginx:rginx /var/lib/rginx >/dev/null 2>&1 || true
        fi

        if [ -x /usr/bin/deb-systemd-helper ]; then
            deb-systemd-helper unmask 'rginx.service' >/dev/null || true

            if deb-systemd-helper --quiet was-enabled 'rginx.service'; then
                deb-systemd-helper enable 'rginx.service' >/dev/null || true
            else
                deb-systemd-helper update-state 'rginx.service' >/dev/null || true
            fi
        fi

        if [ -d /run/systemd/system ]; then
            systemctl --system daemon-reload >/dev/null || true
            if [ -n "$2" ]; then
                action=restart
            else
                action=start
            fi
            if [ -x /usr/bin/deb-systemd-invoke ]; then
                deb-systemd-invoke "$action" 'rginx.service' >/dev/null || true
            else
                systemctl --system "$action" rginx.service >/dev/null 2>&1 || true
            fi
        fi
        ;;
esac

exit 0
