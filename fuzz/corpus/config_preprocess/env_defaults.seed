Config(
    runtime: RuntimeConfig(
        shutdown_timeout_secs: 2,
    ),
    server: ServerConfig(
        listen: "${rginx_fuzz_listen:-127.0.0.1:19090}",
    ),
    upstreams: [],
    locations: [
        LocationConfig(
            matcher: Exact("/"),
            handler: Return(
                status: 200,
                location: "",
                body: Some("$${literal}:${rginx_fuzz_body:-hello}"),
            ),
        ),
    ],
)
