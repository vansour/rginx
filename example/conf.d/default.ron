// conf.d/default.ron single-site fragment example
// conf.d/default.ron 单独网站片段示例
//
// This file is NOT a top-level `Config(...)`.
// 这个文件不是顶层 `Config(...)`。
//
// This file is meant to be included from:
// 这个文件应该被下面这样的主配置 include 进来：
//
// servers: [
//     // @include "conf.d/*.ron"
// ],
//
// In other words:
// - `rginx.ron` contains global runtime/server/upstreams/default-locations
// - `conf.d/default.ron` contains one or more `VirtualHostConfig(...)`
//
// 换句话说：
// - `rginx.ron` 放全局 runtime/server/upstreams/default-locations
// - `conf.d/default.ron` 放一个或多个 `VirtualHostConfig(...)`

VirtualHostConfig(
    // Hostnames matched by this site.
    // Supports exact names and wildcard names like `*.example.com`.
    // 这个站点匹配的域名。
    // 支持精确域名和 `*.example.com` 这类通配域名。
    server_names: [
        "app.example.com",
        "www.app.example.com",
        "*.edge.app.example.com",
    ],

    // Routes that belong only to this site.
    // 只属于这个站点自己的路由。
    locations: [
        LocationConfig(
            // Exact match: `/`
            // 精确匹配：`/`
            matcher: Exact("/"),

            handler: Return(
                // Fixed response status.
                // 固定响应状态码。
                status: 200,

                // Redirect location.
                // Non-redirect response should keep this as `""`.
                // 重定向目标。
                // 非重定向响应时保持 `""`。
                location: "",

                // Optional body.
                // 可选响应体。
                body: Some("app.example.com root\n"),
            ),

            // Optional gRPC narrowing.
            // 可选 gRPC 精细匹配。
            grpc_service: None,
            grpc_method: None,

            // Route allow list.
            // 路由允许列表。
            allow_cidrs: [],

            // Route deny list.
            // 路由拒绝列表。
            deny_cidrs: [],

            // Optional rate limiting.
            // 可选限流。
            requests_per_sec: None,
            burst: None,
        ),

        LocationConfig(
            // Prefix match example.
            // 前缀匹配示例。
            matcher: Prefix("/api"),

            handler: Proxy(
                // Upstream name must be defined in the top-level `rginx.ron`.
                // upstream 名称必须在顶层 `rginx.ron` 里定义。
                upstream: "backend_http",

                // Preserve original Host header.
                // 是否保留原始 Host 头。
                preserve_host: Some(true),

                // Strip `/api` before forwarding to upstream.
                // 转发前剥离 `/api`。
                strip_prefix: Some("/api"),

                // Extra headers sent to upstream.
                // 发送给上游的额外头部。
                proxy_set_headers: {
                    "x-rginx-vhost": "app.example.com",
                    "x-rginx-site": "default-site",
                },
            ),
            grpc_service: None,
            grpc_method: None,
            allow_cidrs: [],
            deny_cidrs: [
                "203.0.113.0/24",
            ],
            requests_per_sec: Some(100),
            burst: Some(50),
        ),

        LocationConfig(
            // gRPC-specific route example.
            // gRPC 专用路由示例。
            matcher: Prefix("/grpc"),
            handler: Proxy(
                upstream: "grpc_secure",
                preserve_host: Some(false),
                strip_prefix: None,
                proxy_set_headers: {
                    "x-rginx-vhost": "app.example.com",
                },
            ),
            grpc_service: Some("com.example.user.UserService"),
            grpc_method: Some("GetUser"),
            allow_cidrs: [],
            deny_cidrs: [],
            requests_per_sec: Some(200),
            burst: Some(100),
        ),
    ],

    // Optional per-site TLS certificate.
    // 可选的站点级 TLS 证书。
    tls: None,

    // Enable this when the site has its own certificate.
    // 当这个站点需要自己的证书时，可以启用下面的块。
    //
    // tls: Some(VirtualHostTlsConfig(
    //     cert_path: "/etc/rginx/certs/app.example.com.crt",
    //     key_path: "/etc/rginx/certs/app.example.com.key",
    // )),
),
